<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-blue-100 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-200">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-blue-600 mb-2">🐦 TwitterClone</h1>
        <h2 class="text-2xl font-semibold text-gray-800">Sign in to your account</h2>
        <p class="text-gray-600 mt-2">Welcome back! Please enter your details.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password, autocomplete: "current-password",
                               class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <%= f.label :remember_me, class: "ml-2 text-sm text-gray-700" %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Sign in", class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-4 rounded-lg transition cursor-pointer shadow-md hover:shadow-lg" %>
        </div>
      <% end %>

      <div class="mt-6 space-y-3">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>