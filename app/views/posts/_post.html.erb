<article class="relative bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-4 transition-all hover:shadow-md group/post">

  <%= link_to "", post_path(post), data: { turbo_frame: "_top" }, class: "absolute inset-0 z-10" %>

  <div class="p-4 sm:p-5">

    <div class="flex items-start justify-between mb-3">

      <div class="relative z-20 flex items-start gap-3 group/user hover:opacity-80 transition-opacity">

        <%= link_to "", user_path(post.user), data: { turbo_frame: "_top" }, class: "absolute inset-0 z-10" %>

        <div class="w-10 h-10 sm:w-11 sm:h-11 bg-gradient-to-br from-blue-50 to-indigo-100 rounded-full flex items-center justify-center text-blue-700 font-extrabold text-lg shadow-inner ring-2 ring-slate-50 group-hover/user:ring-blue-100 transition-all flex-shrink-0">
          <%= post.user.username&.first&.upcase || "👤" %>
        </div>

        <div class="flex flex-col justify-center mt-0.5">
          <span class="font-bold text-slate-900 text-[15px] leading-none group-hover/user:text-blue-600 transition-colors">
            <%= post.user.to_s %>
          </span>

          <div class="flex items-center gap-1.5 text-[11px] sm:text-xs text-slate-500 font-medium mt-1">
            <span>@<%= post.user.username %></span>
            <span class="w-0.5 h-0.5 rounded-full bg-slate-400"></span>
            <span><%= post.created_at.strftime("%d. %b %Y") %></span>
          </div>
        </div>
      </div>

      <div class="relative z-20 flex items-center gap-2 shrink-0">

        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-slate-100 text-slate-600">
          <%= post.status %>
        </span>

        <% if post.user == current_user %>
          <%= link_to edit_post_path(post), class: "text-slate-400 hover:text-slate-600 bg-slate-50 hover:bg-slate-200 p-1.5 rounded-full transition-colors relative z-30", title: "Edit post" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          <% end %>
        <% end %>

      </div>
    </div>

    <div class="relative z-20 mt-3 pointer-events-none">
      <h2 class="text-lg font-bold text-slate-900 mb-1.5 leading-snug group-hover/post:text-blue-700 transition-colors">
        <%= post.title %>
      </h2>
      <div class="text-slate-800 text-[15px] sm:text-base leading-relaxed break-words">
        <p><%= post.body %></p>
      </div>
    </div>

  </div>

  <div class="relative z-20 px-4 py-2 sm:px-5 sm:py-3 bg-slate-50/50 border-t border-slate-100 flex items-center justify-start gap-4 sm:gap-6 text-sm font-medium text-slate-500">

    <button class="flex items-center gap-2 hover:text-red-600 hover:bg-red-50 px-3 py-1.5 rounded-md transition-colors group/btn">
      <svg class="w-5 h-5 text-slate-400 group-hover/btn:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      <span class="hidden sm:inline">Like</span>
      <span class="bg-slate-200 group-hover/btn:bg-red-100 group-hover/btn:text-red-600 text-slate-600 px-1.5 py-0.5 rounded text-xs transition-colors">12</span>
    </button>

    <button class="flex items-center gap-2 hover:text-blue-600 hover:bg-blue-50 px-3 py-1.5 rounded-md transition-colors group/btn">
      <svg class="w-5 h-5 text-slate-400 group-hover/btn:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      <span class="hidden sm:inline">Comment</span>
      <span class="bg-slate-200 group-hover/btn:bg-blue-100 group-hover/btn:text-blue-600 text-slate-600 px-1.5 py-0.5 rounded text-xs transition-colors">3</span>
    </button>

  </div>
</article>