<% @users.each do |user| %>
  <div class="relative px-3 py-2 border-b border-slate-100 hover:bg-slate-50 transition-colors group cursor-pointer">

    <%= link_to "", user_path(user), data: { turbo_frame: "_top" }, class: "absolute inset-0 z-10" %>

    <div class="flex items-center justify-between">

      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-50 to-indigo-100 rounded-full flex items-center justify-center text-blue-700 font-extrabold text-sm shadow-inner ring-2 ring-white flex-shrink-0 group-hover:scale-105 transition-transform">
          <%= user.username&.first&.upcase || "👤" %>
        </div>

        <div class="flex flex-col">
          <span class="font-bold text-slate-900 text-xs sm:text-sm leading-tight group-hover:text-blue-600 transition-colors relative z-20 pointer-events-none">
            <%= user.to_s %>
          </span>
        </div>
      </div>

    </div>
  </div>
<% end %>