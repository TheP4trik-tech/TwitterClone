
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 py-6 sm:py-10 px-3 sm:px-4">
  <div class="max-w-2xl mx-auto space-y-4 sm:space-y-6">
    <%= turbo_frame_tag @user do %>
      <div class="bg-white/80 backdrop-blur-xl rounded-2xl sm:rounded-3xl shadow-lg shadow-blue-100/50 border border-white/60 overflow-hidden">

        <div class="h-24 sm:h-32 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 relative">
          <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.2),transparent_70%)]"></div>
        </div>

        <div class="px-4 sm:px-8 pb-6 sm:pb-8">
          <% if @user == current_user %>
            <div class="flex justify-end pt-3 sm:pt-4 relative z-30">
              <%= link_to edit_user_path(@user),
                          class: "inline-flex items-center gap-1.5 text-xs sm:text-sm font-medium text-slate-600 hover:text-blue-600 bg-white/80 hover:bg-white border border-slate-200 hover:border-blue-300 rounded-full px-3 sm:px-4 py-1 sm:py-1.5 transition-all duration-200 shadow-sm hover:shadow" do %>
                <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                </svg>
                Edit profile
              <% end %>
            </div>
          <% end %>

          <div class="relative flex flex-col items-center <%= @user == current_user ? '-mt-14 sm:-mt-16' : '-mt-16 sm:-mt-20' %>">


            <div class="w-20 h-20 sm:w-28 sm:h-28 bg-white rounded-full p-0.5 sm:p-1 shadow-lg ring-4 ring-white flex-shrink-0 z-10 mx-auto">
              <div class="w-full h-full bg-gradient-to-br from-blue-50 to-indigo-100 rounded-full flex items-center justify-center text-blue-700 font-extrabold text-3xl sm:text-4xl shadow-inner">
                <%= @user.username&.first&.upcase || "👤" %>
              </div>
            </div>
            <div class="text-center mt-3 sm:mt-4 w-full">
              <h1 class="text-xl sm:text-2xl font-extrabold text-slate-900 tracking-tight"><%= @user.to_s %></h1>
              <p class="text-slate-400 text-xs sm:text-sm mt-0.5">@<%= @user.username %></p>

              <p class="mt-2.5 sm:mt-3 text-slate-500 text-sm sm:text-base max-w-xs sm:max-w-md mx-auto leading-relaxed px-2">
                <% if @user.bio.blank? %>
                  <span class="text-slate-400 italic text-xs sm:text-sm">No bio yet</span>
                <% else %>
                  <%= @user.bio %>
                <% end %>
              </p>

              <% if @user != current_user %>
                <div class="mt-4 sm:mt-5">
                  <% if current_user.is_following?(@user) %>
                    <%= button_to "Unfollow", user_follow_path(@user, current_user.get_follow_id(@user)), method: :delete, class: "bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-2 px-6 sm:px-8 rounded-full transition-all duration-200 transform hover:scale-105 shadow-lg shadow-blue-200/50 text-sm sm:text-base" %>
                  <% else %>
                    <%= button_to "Follow", user_follows_path(@user), method: :post, class: "bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-2 px-6 sm:px-8 rounded-full transition-all duration-200 transform hover:scale-105 shadow-lg shadow-blue-200/50 text-sm sm:text-base" %>
                  <% end %>
                </div>
              <% end %>
            </div>


            <div class="grid grid-cols-3 gap-2 sm:gap-4 w-full mt-6 sm:mt-8 pt-5 sm:pt-6 border-t border-slate-100">

              <div class="text-center">
                <span class="block font-extrabold text-slate-900 text-base sm:text-xl"><%= @user.user_total_posts %></span>
                <span class="text-slate-400 text-[10px] sm:text-xs uppercase font-semibold tracking-wider">Posts</span>
              </div>
              <div class="text-center">
              <span class="relative block font-extrabold text-slate-900 text-base sm:text-xl hover:text-blue-600 transition-colors">
                <% if @user.followers.any? %>
                  <%= link_to "", user_followers_path(@user), data: { turbo_frame: "modal" }, class: "absolute inset-0 z-10" %>
                <% end %>
                <%= @user.user_total_followers %>
              </span>
                <span class="text-slate-400 text-[10px] sm:text-xs uppercase font-semibold tracking-wider">Followers</span>
              </div>
              <div class="text-center">
              <span class="relative block font-extrabold text-slate-900 text-base sm:text-xl hover:text-blue-600 transition-colors">
                <% if @user.following.any? %>
                  <%= link_to "", user_following_index_path(@user), data: { turbo_frame: "modal" }, class: "absolute inset-0 z-10" %>
                <% end %>
                <%= @user.user_total_following %>
              </span>
                <span class="text-slate-400 text-[10px] sm:text-xs uppercase font-semibold tracking-wider">Following</span>
              </div>
            </div>

          </div>
        </div>
      </div>
    <% end %>
    <br>
    <div class="space-y-3 sm:space-y-4">
      <h3 class="text-[10px] sm:text-xs font-bold text-slate-400 px-1 sm:px-2 uppercase tracking-widest">Posts</h3>

      <div class="bg-white/80 backdrop-blur-xl rounded-xl sm:rounded-2xl shadow-sm p-3.5 sm:p-5 border border-white/60 hover:shadow-md hover:border-blue-100/80 transition-all duration-200 group">

        <% if @user.posts.any? %>
          <%= render @user.posts %>
        <% end %>
      </div>
    </div>
  </div>
</div>
